<?xml version="1.0" encoding="utf-8"?>
<!--
    layout-land/activity_main.xml  (landscape / Android TV)
    Apple TV-style home screen — landscape variant.
    Differences from portrait:
      - Top bar taller (56dp), tabs bigger font (15sp)
      - Cards wider via override in adapter (200dp live, 160dp poster)
      - Section title 20sp
      - Bottom bar shows text labels under icons
      - Full-screen preview player layer behind UI (TV mode)
    All original IDs from MainActivity.java are preserved.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ================================================ -->
    <!-- LAYER 0: Full-screen video preview (TV mode)     -->
    <!-- ================================================ -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/preview_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit"
        android:background="@android:color/black"
        android:clickable="false"
        android:focusable="false" />

    <!-- Subtle dark vignette over video to keep UI readable -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:clickable="false"
        android:focusable="false" />

    <!-- ================================================ -->
    <!-- LAYER 1: Apple TV home UI                        -->
    <!-- ================================================ -->
    <LinearLayout
        android:id="@+id/overlay_browse"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- TOP BAR — Apple TV-style: transparent gradient, text-only tabs, no chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/gradient_top_bar"
            android:paddingTop="8dp"
            android:elevation="8dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- App logo -->
            <ImageView
                android:layout_width="140dp"
                android:layout_height="26dp"
                android:src="@drawable/logo_salliptv"
                android:scaleType="fitStart"
                android:contentDescription="@string/app_name"
                android:layout_marginEnd="24dp" />

            <!-- Tabs — inline (no HorizontalScrollView needed on wide TV screen) -->

            <!-- Hidden sidebar stubs required by code -->
            <LinearLayout
                android:id="@+id/sidebar_tabs"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:orientation="vertical"
                android:visibility="gone">
                <TextView android:id="@+id/tab_live"      android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tab_vod"       android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tab_series"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tab_favorites" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tab_recent"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
                <TextView android:id="@+id/tab_settings"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tab_home_vis"
                android:nextFocusDown="@id/recyclerSections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_home"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true" />

            <TextView
                android:id="@+id/tab_live_vis"
                android:nextFocusDown="@id/recyclerSections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_live"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true" />

            <TextView
                android:id="@+id/tab_vod_vis"
                android:nextFocusDown="@id/recyclerSections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_vod"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true" />

            <TextView
                android:id="@+id/tab_series_vis"
                android:nextFocusDown="@id/recyclerSections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_series"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true" />

            <TextView
                android:id="@+id/tab_favorites_vis"
                android:nextFocusDown="@id/recyclerSections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_favorites"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true" />

            <TextView
                android:id="@+id/tab_recent_vis"
                android:nextFocusDown="@id/recyclerSections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tab_recent"
                android:textColor="#8E8E93"
                android:textSize="16sp"
                android:fontFamily="sans-serif"
                android:gravity="center"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:layout_marginEnd="24dp"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Settings icon in top bar (TV) -->
            <ImageView
                android:id="@+id/icon_settings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_settings"
                android:scaleType="fitCenter"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true"
                android:layout_marginEnd="16dp"
                android:contentDescription="@null" />

            <!-- Search icon in top bar (TV) -->
            <ImageView
                android:id="@+id/icon_search"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_search"
                android:scaleType="fitCenter"
                android:focusable="true"
                android:focusableInTouchMode="true"                android:clickable="true"
                android:layout_marginStart="16dp"
                android:contentDescription="@null" />

        </LinearLayout>

        <!-- Contextual search/filter bar (toggled by search icon) -->
        <LinearLayout
            android:id="@+id/search_filter_bar"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1A1A1A"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone"
            android:focusable="false">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:layout_marginEnd="12dp"
                android:alpha="0.5"
                android:contentDescription="@null" />

            <EditText
                android:id="@+id/et_filter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/hint_search_filter"
                android:textColorHint="#666666"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:focusable="true"
                android:focusableInTouchMode="true" />

            <ImageView
                android:id="@+id/btn_clear_filter"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:scaleType="fitCenter"
                android:padding="4dp"
                android:focusable="true"
                android:focusableInTouchMode="true"
                android:clickable="true"
                android:visibility="gone"
                android:contentDescription="@null" />
        </LinearLayout>

        <!-- SECTION CAROUSELS -->

        <!-- Hidden text stubs required by code -->
        <TextView android:id="@+id/tv_sidebar_back"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_category_name"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_channel_count"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_program_title"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_program_time"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_program_duration" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_program_desc"    android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_date_time"       android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <ProgressBar android:id="@+id/progress"        android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <ProgressBar android:id="@+id/pb_program_progress" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        <TextView android:id="@+id/tv_status"          android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" android:textColor="#8E8E93" android:textSize="16sp" android:layout_gravity="center" />
        <TextView android:id="@+id/tv_preview_channel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        <!-- LIVE LIST MODE: categories sidebar + channel list -->
        <LinearLayout
            android:id="@+id/live_list_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:visibility="gone">

            <!-- Categories sidebar -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_categories"
                android:layout_width="220dp"
                android:layout_height="match_parent"
                android:nextFocusUp="@id/tab_live_vis"
                android:background="#0D0D0D"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#1C1C1E" />

            <!-- Channel list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_channels"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:nextFocusUp="@id/tab_live_vis"
                android:layout_weight="1"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:clipToPadding="false" />
        </LinearLayout>

        <!-- CAROUSEL MODE: home sections -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:overScrollMode="never"
            android:nextFocusUp="@id/tab_home_vis"
            android:paddingBottom="16dp" />

    </LinearLayout>

    <!-- ================================================ -->
    <!-- LAYER 3: EPG overlay (kept for MainActivity compat) -->
    <!-- ================================================ -->
    <LinearLayout
        android:id="@+id/epg_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F0000000"
        android:layout_marginStart="0dp"
        android:visibility="gone">

        <!-- Time header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <View
                android:layout_width="200dp"
                android:layout_height="40dp"
                android:background="#0A0A0A" />

            <HorizontalScrollView
                android:id="@+id/epg_hsv_time_header"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:scrollbars="none"
                android:background="#0A0A0A">

                <LinearLayout
                    android:id="@+id/epg_ll_time_slots"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A1A2E" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/epg_rv_channels"
                android:layout_width="200dp"
                android:layout_height="match_parent"
                android:background="#0A0A0A"
                android:scrollbars="none" />

            <HorizontalScrollView
                android:id="@+id/epg_hsv_programs"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:scrollbars="none">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/epg_rv_programs"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:scrollbars="none" />
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/epg_info_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#1C1C1E"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/epg_iv_channel_logo"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="fitCenter"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/epg_tv_program_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/epg_tv_program_time"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#8E8E93"
                    android:textSize="13sp"
                    android:maxLines="1" />
            </LinearLayout>

            <TextView
                android:id="@+id/epg_tv_program_desc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#666666"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingStart="16dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Sidebar groups stub (required by code) -->
    <LinearLayout
        android:id="@+id/sidebar_groups"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/icon_bar"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            android:visibility="gone">
            <ImageView android:id="@+id/icon_tv"       android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageView android:id="@+id/icon_vod"      android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageView android:id="@+id/icon_series"   android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageView android:id="@+id/icon_epg"      android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageView android:id="@+id/icon_history"  android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
            <ImageView android:id="@+id/icon_favorite" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
