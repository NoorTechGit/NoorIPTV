<?xml version="1.0" encoding="utf-8"?>
<!--
    Apple TV style episode card
    300dp wide, thumbnail (300x170) + info below
    Rounded top corners via bg_episode_card
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:focusable="true"
                android:focusableInTouchMode="true"    android:clickable="true"
    android:background="@drawable/bg_episode_card">

    <!-- ================================================ -->
    <!-- THUMBNAIL AREA (300x170, covers top of card)     -->
    <!-- ================================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Thumbnail frame -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="170dp">

            <!-- Episode thumbnail image -->
            <ImageView
                android:id="@+id/iv_episode_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="#1C1C1E" />

            <!-- Subtle play icon overlay (centered) -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle"
                android:alpha="0.75" />

            <!-- Episode number badge: top-left, gray, 12sp, "E1" format -->
            <TextView
                android:id="@+id/tv_episode_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:background="@drawable/bg_badge_rating"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Duration badge: bottom-right -->
            <TextView
                android:id="@+id/tv_episode_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_badge_rating"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:textColor="#8E8E93"
                android:textSize="12sp" />
        </FrameLayout>

        <!-- ============================================ -->
        <!-- EPISODE INFO BELOW THUMBNAIL                 -->
        <!-- title (white 14sp) + plot (gray 12sp, 2 lines) -->
        <!-- ============================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1C1C1E"
            android:padding="10dp">

            <!-- Episode title: white, 14sp, bold -->
            <TextView
                android:id="@+id/tv_episode_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Plot / synopsis: secondary gray, 12sp, 2 lines -->
            <TextView
                android:id="@+id/tv_episode_plot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#8E8E93"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingTop="4dp"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
