<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipChildren="false">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_dark"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:maxWidth="600dp"
            android:layout_gravity="center_horizontal">

            <!-- ============================================ -->
            <!-- SECTION: QR Code / Device Link              -->
            <!-- ============================================ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_settings_row"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- QR Code (smaller, left side) -->
                <ImageView
                    android:id="@+id/iv_qr_code"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:background="@android:color/white"
                    android:padding="6dp"
                    android:layout_marginEnd="20dp"
                    android:contentDescription="@string/qr_instructions" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/web_companion_title"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:paddingBottom="6dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/web_companion_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:lineSpacingMultiplier="1.2"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_device_id"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:id="@+id/tv_premium_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/premium_subtitle"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:paddingTop="4dp" />

                    <TextView
                        android:id="@+id/tv_sync_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/waiting_for_sync"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:alpha="0.7"
                        android:paddingTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============================================ -->
            <!-- SECTION: Playlists                          -->
            <!-- ============================================ -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/saved_playlists"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp"
                android:paddingTop="4dp" />

            <TextView
                android:id="@+id/tv_no_playlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_playlist"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:paddingTop="4dp"
                android:paddingBottom="12dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_playlists"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="8dp"
                android:clipChildren="false"
                android:clipToPadding="false" />

            <TextView
                android:id="@+id/btn_show_manual"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="@string/manual_add"
                android:textColor="@color/text_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:background="@drawable/bg_chip"
                android:focusable="true"
                    android:focusableInTouchMode="true"            android:clickable="true" />

            <!-- Manual input (hidden by default) -->
            <LinearLayout
                android:id="@+id/layout_manual_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:paddingTop="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/playlist_name"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="4dp" />

                <EditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="My IPTV"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="text"
                    android:singleLine="true"
                    android:focusable="true" />

                <!-- Type Toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="12dp"
                    android:paddingBottom="8dp">

                    <TextView
                        android:id="@+id/btn_type_m3u"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="@string/playlist_type_m3u"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:background="@drawable/bg_toggle_active"
                        android:layout_marginEnd="4dp"
                        android:focusable="true"
                    android:focusableInTouchMode="true"                    android:clickable="true" />

                    <TextView
                        android:id="@+id/btn_type_xtream"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="@string/playlist_type_xtream"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:background="@drawable/bg_chip"
                        android:layout_marginStart="4dp"
                        android:focusable="true"
                    android:focusableInTouchMode="true"                    android:clickable="true" />
                </LinearLayout>

                <!-- M3U Fields -->
                <LinearLayout
                    android:id="@+id/layout_m3u"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/m3u_url"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:paddingBottom="4dp"
                        android:paddingTop="4dp" />

                    <EditText
                        android:id="@+id/et_m3u_url"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="http://..."
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textUri|textNoSuggestions"
                        android:imeOptions="flagNoExtractUi|flagNoFullscreen"
                        android:importantForAutofill="no"
                        android:singleLine="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- Xtream Fields -->
                <LinearLayout
                    android:id="@+id/layout_xtream"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/xtream_server"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:paddingBottom="4dp"
                        android:paddingTop="4dp" />

                    <EditText
                        android:id="@+id/et_server"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:hint="http://server.com:8080"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textUri|textNoSuggestions"
                        android:imeOptions="flagNoExtractUi|flagNoFullscreen"
                        android:importantForAutofill="no"
                        android:singleLine="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/xtream_username"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:paddingBottom="4dp"
                        android:paddingTop="8dp" />

                    <EditText
                        android:id="@+id/et_username"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="text"
                        android:singleLine="true"
                        android:focusable="true" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/xtream_password"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:paddingBottom="4dp"
                        android:paddingTop="8dp" />

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:background="@drawable/bg_chip"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:inputType="textPassword"
                        android:singleLine="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- EPG URL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/epg_url"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:paddingBottom="4dp"
                    android:paddingTop="12dp" />

                <EditText
                    android:id="@+id/et_epg_url"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:hint="http://epg.example.com/epg.xml"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:inputType="textUri|textNoSuggestions"
                    android:imeOptions="flagNoExtractUi|flagNoFullscreen"
                    android:importantForAutofill="no"
                    android:singleLine="true"
                    android:focusable="true" />

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="16dp">

                    <TextView
                        android:id="@+id/btn_test"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="@string/btn_test"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@drawable/bg_chip"
                        android:layout_marginEnd="6dp"
                        android:focusable="true"
                    android:focusableInTouchMode="true"                    android:clickable="true" />

                    <TextView
                        android:id="@+id/btn_save"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="@string/btn_save"
                        android:textColor="#000000"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:background="@drawable/bg_button_white"
                        android:focusable="true"
                    android:focusableInTouchMode="true"                    android:clickable="true" />
                </LinearLayout>

                <!-- Status -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingTop="12dp">

                    <ImageView
                        android:id="@+id/progress_status"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_aura_logo"
                        android:layout_marginEnd="8dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- ============================================ -->
            <!-- SECTION: Player Settings                    -->
            <!-- ============================================ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/separator"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_player_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp" />

            <!-- Buffer size -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="2dp"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_buffer"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_buffer_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Decoder -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="2dp"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_decoder"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_decoder_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hardware"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Aspect Ratio -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_aspect_ratio"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_aspect_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fit"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ============================================ -->
            <!-- SECTION: General                            -->
            <!-- ============================================ -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="@color/separator"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_general_title"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp" />

            <!-- Clear cache -->
            <LinearLayout
                android:id="@+id/btn_clear_cache"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginBottom="2dp"
                android:focusable="true"
                    android:focusableInTouchMode="true"            android:clickable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_clear_cache"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_cache_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- App version -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_settings_row"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:focusable="true">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_version"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Bottom padding -->
            <View
                android:layout_width="match_parent"
                android:layout_height="40dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Loading overlay -->
    <LinearLayout
        android:id="@+id/overlay_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/progress_overlay"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_aura_logo" />

        <TextView
            android:id="@+id/tv_overlay_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:paddingTop="16dp" />

        <TextView
            android:id="@+id/tv_overlay_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#8E8E93"
            android:textSize="13sp"
            android:paddingTop="6dp" />
    </LinearLayout>

</FrameLayout>
