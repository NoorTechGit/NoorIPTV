<?xml version="1.0" encoding="utf-8"?>
<!--
    item_home_card_poster.xml
    Portrait poster card for VOD / Series (130x195dp).
    Focus: scale 1.08 + elevation 8dp (card_focus_animator).
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="130dp"
    android:layout_height="195dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#1C1C1E"
    app:cardElevation="0dp"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:stateListAnimator="@animator/card_focus_animator">

    <!-- Poster image -->
    <ImageView
        android:id="@+id/iv_poster"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Gradient bottom overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_card_poster_bottom"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp"
        android:paddingTop="32dp">

        <TextView
            android:id="@+id/tv_poster_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_poster_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end"
            android:paddingTop="2dp" />
    </LinearLayout>

    <!-- Centered play icon overlay (semi-transparent, shown on focus) -->
    <ImageView
        android:id="@+id/iv_play_overlay"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_play_overlay"
        android:scaleType="fitCenter"
        android:alpha="0"
        android:contentDescription="@null" />

    <!-- Rating badge (top-left) -->
    <TextView
        android:id="@+id/tv_poster_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="6dp"
        android:textColor="@color/text_primary"
        android:textSize="9sp"
        android:fontFamily="sans-serif-medium"
        android:background="@color/surface"
        android:paddingStart="5dp"
        android:paddingEnd="5dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone" />

    <!-- Favorite badge (top-right) -->
    <ImageView
        android:id="@+id/iv_poster_favorite"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_heart"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:contentDescription="@null" />

</androidx.cardview.widget.CardView>
