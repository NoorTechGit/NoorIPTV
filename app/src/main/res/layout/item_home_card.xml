<?xml version="1.0" encoding="utf-8"?>
<!--
    item_home_card.xml
    Landscape/live channel card (160x90dp).
    Focus: scale 1.08 + elevation 8dp (driven by card_focus_animator).
    The background selector swaps between bg_card_normal and bg_card_focused.
-->
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="160dp"
    android:layout_height="90dp"
    android:layout_margin="4dp"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#1C1C1E"
    app:cardElevation="0dp"
    android:focusable="true"
    android:focusableInTouchMode="false"
    android:stateListAnimator="@animator/card_focus_animator">

    <!-- Channel logo / thumbnail -->
    <ImageView
        android:id="@+id/iv_card_thumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:contentDescription="@null" />

    <!-- Gradient overlay at bottom -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/gradient_card_bottom"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="6dp"
        android:paddingTop="18dp">

        <TextView
            android:id="@+id/tv_card_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_card_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Favorite badge (top-right) -->
    <ImageView
        android:id="@+id/iv_card_favorite"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_gravity="top|end"
        android:layout_margin="6dp"
        android:src="@drawable/ic_heart"
        android:scaleType="fitCenter"
        android:visibility="gone"
        android:contentDescription="@null" />

    <!-- Live badge (top-left) -->
    <TextView
        android:id="@+id/tv_card_live_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="6dp"
        android:text="EN DIRECT"
        android:textColor="@color/text_primary"
        android:textSize="8sp"
        android:fontFamily="sans-serif-medium"
        android:background="@color/accent"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:visibility="gone" />

    <!-- Focus ring overlay (drawn on top when focused, handled by bg_card_focused selector) -->

</androidx.cardview.widget.CardView>
