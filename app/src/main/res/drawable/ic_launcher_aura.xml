<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0A0A0E" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- AURA halo centered -->
    <item
        android:left="20dp"
        android:right="20dp"
        android:top="20dp"
        android:bottom="20dp"
        android:drawable="@drawable/ic_aura_logo" />
</layer-list>
