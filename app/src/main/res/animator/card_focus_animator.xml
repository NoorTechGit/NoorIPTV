<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <set>
            <objectAnimator android:propertyName="scaleX" android:valueTo="1.06" android:duration="150" android:interpolator="@android:anim/decelerate_interpolator" />
            <objectAnimator android:propertyName="scaleY" android:valueTo="1.06" android:duration="150" android:interpolator="@android:anim/decelerate_interpolator" />
            <objectAnimator android:propertyName="translationZ" android:valueTo="6" android:duration="150" android:interpolator="@android:anim/decelerate_interpolator" />
        </set>
    </item>
    <item>
        <set>
            <objectAnimator android:propertyName="scaleX" android:valueTo="1.0" android:duration="150" android:interpolator="@android:anim/decelerate_interpolator" />
            <objectAnimator android:propertyName="scaleY" android:valueTo="1.0" android:duration="150" android:interpolator="@android:anim/decelerate_interpolator" />
            <objectAnimator android:propertyName="translationZ" android:valueTo="0" android:duration="150" android:interpolator="@android:anim/decelerate_interpolator" />
        </set>
    </item>
</selector>
