# SallIPTV Backend Environment Variables
# Copy to .env and fill with real values

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
POSTGRES_USER=iptv
POSTGRES_PASSWORD=change_me_strong_password_123
POSTGRES_DB=iptv

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
JWT_SECRET=change_me_random_64_char_string_here_for_jwt_tokens
ENCRYPTION_KEY=change_me_32_bytes_hex_for_aes_encryption

# ═══════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════
REDIS_URL=redis://salliptv-redis:6379/0

# ═══════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════
DATABASE_URL=postgresql://iptv:change_me_strong_password_123@salliptv-postgres:5432/iptv

# ═══════════════════════════════════════════════════════════════
# UPLOADS
# ═══════════════════════════════════════════════════════════════
UPLOAD_DIR=/tmp/salliptv_uploads

# ═══════════════════════════════════════════════════════════════
# EXTERNAL APIs
# ═══════════════════════════════════════════════════════════════
TMDB_API_KEY=your_tmdb_api_key_here

# ═══════════════════════════════════════════════════════════════
# GLM API (AI enrichment)
# ═══════════════════════════════════════════════════════════════
GLM_API_URL=https://api.z.ai/api/anthropic
GLM_API_KEY=your_glm_api_key_here
GLM_MODEL=glm-4.5-air

# ═══════════════════════════════════════════════════════════════
# DOMAIN (for Traefik)
# ═══════════════════════════════════════════════════════════════
API_DOMAIN=api.salliptv.com

# ═══════════════════════════════════════════════════════════════
# OPTIONAL: Monitoring
# ═══════════════════════════════════════════════════════════════
# FLOWER_PASSWORD=admin_password_for_celery_monitoring
